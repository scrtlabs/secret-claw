{
  "$schema": "https://docs.openclaw.ai/schema/openclaw.json",
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "__GATEWAY_TOKEN__"
    },
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
        "https://__VM_HOSTNAME__"
      ],
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "update": {
    "checkOnStart": false,
    "auto": { "enabled": false }
  },
  "models": {
    "providers": {
      "anthropic": {
        "baseUrl": "https://api.anthropic.com",
        "apiKey": "__ANTHROPIC_API_KEY__",
        "api": "anthropic-messages",
        "timeoutSeconds": 300,
        "contextWindow": 200000,
        "maxTokens": 8192,
        "models": [
          {
            "id": "claude-sonnet-4-6",
            "name": "claude-sonnet-4-6",
            "input": ["text", "image"],
            "contextWindow": 200000,
            "maxTokens": 8192,
            "params": {
              "cacheRetention": "short"
            }
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6"
      },
      "compaction": {
        "reserveTokens": 4096,
        "maxActiveTranscriptBytes": 1000
      },
      "skills": [],
      "bootstrapMaxChars": 2000,
      "bootstrapTotalMaxChars": 8000
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Secret Agent"
      },
      {
        "id": "routines",
        "name": "Secret Agent-routines",
        "workspace": "/home/node/.openclaw/agents/routines/workspace",
        "agentDir": "/home/node/.openclaw/agents/routines/agent",
        "model": "anthropic/claude-sonnet-4-6"
      }
    ]
  },
  "tools": {
    "allow": [
      "read",
      "write",
      "edit",
      "exec",
      "dir_list",
      "web_fetch",
      "message"
    ]
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      },
      "diagnostics-prometheus": {
        "enabled": true
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "__TELEGRAM_BOT_TOKEN__",
      "dmPolicy": "allowlist",
      "allowFrom": ["__TELEGRAM_CHAT_ID__"]
    }
  },
  "commands": {
    "ownerAllowFrom": [
      "telegram:__TELEGRAM_CHAT_ID__"
    ]
  },
  "cron": {
    "enabled": true,
    "store": "/home/node/.openclaw/cron/jobs.json",
    "maxConcurrentRuns": 1
  }
}
