# Placeholder env file. Copy to `.env.local` and fill in for local dev.
# Do NOT commit `.env.local`.

# ── Auth (NextAuth) ───────────────────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — create credentials at console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Database (Prisma / PostgreSQL) ────────────────────────────────────────────
# Connection string for user accounts (sign-up / email confirmation / password reset)
# Example (Neon): postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# ── Email (Postmark) ──────────────────────────────────────────────────────────
# Server API token from postmarkapp.com
POSTMARK_SERVER_TOKEN=
# Verified sender address in your Postmark account
POSTMARK_FROM_EMAIL=secretai@scrtlabs.com
# ─────────────────────────────────────────────────────────────────────────────

# SecretAI portal base URL (production default).
SECRETAI_PORTAL_URL=https://secretai.scrtlabs.com

# ── Portal account silent sync (optional) ─────────────────────────────────────
# When both vars are set the wizard silently syncs the user's SecretAI portal
# account at sign-in: the portal API key and balance are fetched server-to-
# server and stored encrypted in the PortalLink table. No user action needed.
# The feature is disabled while either var is unset.
#
# PORTAL_LINK_ENCRYPTION_KEY — encrypts the stored portal key at rest (AES-256-GCM).
# Generate with: openssl rand -base64 32
PORTAL_LINK_ENCRYPTION_KEY=
#
# PORTAL_SYNC_SECRET — shared secret between wizard and portal for the
# /api/auth/wizard-sync endpoint. Must match WIZARD_SYNC_SECRET on the portal.
# Generate with: openssl rand -hex 32
PORTAL_SYNC_SECRET=

# Anthropic API base URL.
ANTHROPIC_API_URL=https://api.anthropic.com

# Telegram Bot API base URL.
TELEGRAM_API_URL=https://api.telegram.org

# The hostname we burn into openclaw.json's controlUi.allowedOrigins at
# render time. The SecretAI portal assigns a real hostname after vm/create;
# until that hostname is known we render with the wildcard pattern so the
# initial seed doesn't reject the eventual hostname. See render.ts.
DEFAULT_CONTROL_UI_HOSTNAME=*.vm.scrtlabs.com
