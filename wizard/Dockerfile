# Secret Claw wizard — production Dockerfile.
#
# Two-stage build producing a small image with the Next.js standalone server
# (output: 'standalone' in next.config.js) and the deploy templates bundled
# in at /app/templates. Works locally via docker compose and as the eventual
# production deploy artifact (SecretVM, Fly, generic VM host).
#
# Build context is the secret-claw/ repo root, not wizard/ — docker-compose.yml
# sets `context: ..` so the Dockerfile can COPY both `wizard/` and the
# `deploys/<runtime>/<tier>/templates/` trees. To build by hand from secret-claw/:
#
#   docker build -f wizard/Dockerfile -t secret-claw-wizard .
#
# Templates live OUTSIDE wizard/ in the source tree but get baked INSIDE the
# image at /app/templates. SECRET_CLAW_TEMPLATES_DIR points lib/render.ts at
# them. This decouples the runtime artifact from the source tree layout.

# ---------- Stage 1: install deps ----------
FROM node:20-alpine AS deps
WORKDIR /app
COPY wizard/package.json wizard/package-lock.json* ./
RUN npm ci
# Generate Prisma client for the Alpine (musl) target
COPY wizard/prisma ./prisma
RUN npx prisma generate

# ---------- Stage 2: build ----------
FROM node:20-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY wizard/. ./
# Pre-populate ./templates/<runtime>/<tier>/ from the canonical
# deploys/<runtime>/<tier>/templates sources. The npm `prebuild` hook
# (scripts/copy-templates.mjs) would also do this, but its source path
# (../deploys/) doesn't exist in this builder stage's filesystem.
# Copying here lets prebuild see ./templates already populated and skip
# silently.
COPY deploys/openclaw/byo/templates ./templates/openclaw/byo
COPY deploys/openclaw/secret/templates ./templates/openclaw/secret
# Hermes templates land in Phase B. The COPYs below will fail at build
# time until the dest directories exist in the source tree — that's
# desired (early failure if a Hermes-runtime deploy hits a missing
# template). Uncomment as Hermes templates are added:
# COPY deploys/hermes/byo/templates ./templates/hermes/byo
# COPY deploys/hermes/secret/templates ./templates/hermes/secret
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

# ---------- Stage 3: runtime ----------
FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
# DATABASE_URL and other secrets are injected at runtime via docker-compose / env
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
# render.ts checks this env first; falls back to ../deploys/<runtime>/<tier>/templates
# relative to cwd otherwise. Inside the container the templates live at
# /app/templates/<runtime>/<tier>/, copied in below.
ENV SECRET_CLAW_TEMPLATES_DIR=/app/templates

# Run as a non-root user. Next.js standalone server.js binds the port the
# `node` user can use (3000 is unprivileged on Linux).
RUN addgroup --system --gid 1001 nodejs \
 && adduser --system --uid 1001 nextjs

# Standalone output: a self-contained server.js + pruned node_modules.
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
# Static assets that the standalone server expects to find under .next/static.
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

# Deploy templates baked into the image. Pulled from the builder stage so
# the runtime image has a single source of truth (matches what the build
# saw). resolveTemplatesDir() in lib/render.ts reads them from
# SECRET_CLAW_TEMPLATES_DIR=/app/templates.
COPY --from=builder --chown=nextjs:nodejs /app/templates ./templates

# Prisma client engine (generated for linux-musl in deps stage)
COPY --from=deps --chown=nextjs:nodejs /app/node_modules/.prisma ./node_modules/.prisma

USER nextjs
EXPOSE 3000

# server.js is generated by Next.js standalone build at .next/standalone/server.js.
# After the COPY --from=builder above, it lives at /app/server.js.
CMD ["node", "server.js"]
