generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PortalLink {
  id           String   @id @default(cuid())
  userSub      String   @unique
  email        String?
  apiKeyCipher String
  balance      Float    @default(0)
  linkedAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id                       String        @id @default(cuid())
  email                    String        @unique
  sub                      String        @unique
  passwordHash             String?
  emailConfirmed           Boolean       @default(false)
  emailConfirmationToken   String?       @unique
  emailConfirmationExpires DateTime?
  passwordResetToken       String?       @unique
  passwordResetExpires     DateTime?
  createdAt                DateTime      @default(now())
  lastLogin                DateTime      @updatedAt
  agents                   Agent[]       @relation("UserAgents")
  subscription             Subscription?
}

model Subscription {
  id                      String    @id @default(cuid())
  userSub                 String    @unique
  bluesnapSubscriptionId  String    @unique
  bluesnapVaultedShopperId String?
  planId                  String
  // trialing | active | past_due | canceled
  status                  String
  trialEndsAt             DateTime?
  currentPeriodEnd        DateTime?
  cancelAtPeriodEnd       Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user                    User      @relation(fields: [userSub], references: [sub])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Agent {
  id                  String    @id @default(cuid())
  deploymentId        String    @unique
  userSub             String
  status              String
  runtime             String
  tier                String
  secretaiModel       String?
  vmId                String?
  vmHostname          String?
  jobId               String?
  gatewayToken        String?
  telegramEnabled     Boolean   @default(false)
  telegramBotUsername String?
  errorMessage        String?
  createdAt           DateTime
  provisionedAt       DateTime?
  updatedAt           DateTime  @updatedAt

  user                User      @relation("UserAgents", fields: [userSub], references: [sub])

  @@index([userSub])
}
